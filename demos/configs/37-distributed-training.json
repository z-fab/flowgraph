  "scenario": {
    "loop": true,
    "playInterval": 600,
    "narration": {
      "showOnCanvas": true,
      "position": "top-left"
    },
    "steps": [
      {
        "narrate": {
          "title": "Treino distribuído (DDP)",
          "description": "O batch global é dividido em 3 shards; cada GPU faz forward/backward local e sincroniza gradientes via all-reduce.",
          "ms": 950
        }
      },
      {
        "travel": {
          "edge": "eb",
          "token": "default",
          "title": "Global batch → Shard split",
          "description": "Batch efetivo = soma dos micro-batches locais."
        }
      },
      {
        "dwell": {
          "node": "split",
          "effect": "processing",
          "ms": 220,
          "title": "Shard split",
          "description": "Divide o batch em 3 partes iguais (÷3)."
        }
      },
      {
        "narrate": {
          "title": "Fan-out — 3 GPUs em paralelo",
          "description": "Cada rank recebe seu shard e executa o passo de treino independentemente.",
          "ms": 750
        }
      },
      {
        "parallel": [
          {
            "travel": {
              "edge": "er0",
              "token": "default",
              "title": "→ GPU 0",
              "description": "shard 0"
            }
          },
          {
            "travel": {
              "edge": "er1",
              "token": "default",
              "title": "→ GPU 1",
              "description": "shard 1",
              "delay": 100
            }
          },
          {
            "travel": {
              "edge": "er2",
              "token": "default",
              "title": "→ GPU 2",
              "description": "shard 2",
              "delay": 200
            }
          }
        ]
      },
      {
        "parallel": [
          {
            "dwell": {
              "node": "r0",
              "effect": "processing",
              "ms": 500,
              "title": "GPU 0",
              "description": "Forward + backward local."
            }
          },
          {
            "dwell": {
              "node": "r1",
              "effect": "processing",
              "ms": 500,
              "title": "GPU 1",
              "delay": 80
            }
          },
          {
            "dwell": {
              "node": "r2",
              "effect": "processing",
              "ms": 500,
              "title": "GPU 2",
              "delay": 160
            }
          }
        ]
      },
      {
        "narrate": {
          "title": "All-Reduce",
          "description": "Gradientes locais são somados e replicados em todos os ranks — modelo idêntico em cada GPU.",
          "ms": 800
        }
      },
      {
        "parallel": [
          {
            "travel": {
              "edge": "gr0",
              "token": "default",
              "title": "GPU 0 → All-Reduce"
            }
          },
          {
            "travel": {
              "edge": "gr1",
              "token": "default",
              "title": "GPU 1 → All-Reduce",
              "delay": 100
            }
          },
          {
            "travel": {
              "edge": "gr2",
              "token": "default",
              "title": "GPU 2 → All-Reduce",
              "delay": 200
            }
          }
        ]
      },
      {
        "dwell": {
          "node": "ar",
          "effect": "processing",
          "ms": 420,
          "title": "All-Reduce",
          "description": "Ring all-reduce: Σ grad_local / world_size."
        }
      },
      {
        "travel": {
          "edge": "ao",
          "token": "default",
          "title": "All-Reduce → Optimizer",
          "description": "Gradientes sincronizados alimentam o step."
        }
      },
      {
        "dwell": {
          "node": "optim",
          "effect": "processing",
          "ms": 300,
          "title": "Optimizer",
          "description": "optimizer.step() — mesmos pesos em todas as GPUs."
        }
      },
      {
        "travel": {
          "edge": "od",
          "token": "default",
          "title": "Step complete",
          "description": "Um training step distribuído concluído."
        }
      },
      {
        "wait": {
          "ms": 1200
        }
      }
    ]
  }
}
