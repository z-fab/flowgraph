  "scenario": {
    "loop": true,
    "playInterval": 600,
    "narration": {
      "showOnCanvas": true,
      "position": "top-left"
    },
    "steps": [
      {
        "narrate": {
          "title": "Bloco Transformer",
          "description": "Atenção multi-cabeça paralela, concatenação fan-in e FFN com residual.",
          "ms": 900
        }
      },
      {
        "travel": {
          "edge": "e0",
          "token": "default",
          "title": "Embeddings → MHA",
          "description": "Projeções Q, K, V a partir dos tokens."
        }
      },
      {
        "dwell": {
          "node": "mha",
          "effect": "processing",
          "ms": 450,
          "title": "Multi-Head Attn",
          "description": "Divide d_model em 4 subespaços independentes."
        }
      },
      {
        "narrate": {
          "title": "Fan-out — heads paralelas",
          "description": "Cada cabeça calcula softmax(QKᵀ/√d)V em paralelo.",
          "ms": 700
        }
      },
      {
        "parallel": [
          {
            "travel": {
              "edge": "eh1",
              "token": "default",
              "title": "→ Head 1"
            }
          },
          {
            "travel": {
              "edge": "eh2",
              "token": "default",
              "title": "→ Head 2",
              "delay": 100
            }
          },
          {
            "travel": {
              "edge": "eh3",
              "token": "default",
              "title": "→ Head 3",
              "delay": 200
            }
          }
        ]
      },
      {
        "parallel": [
          {
            "dwell": {
              "node": "h1",
              "effect": "processing",
              "ms": 400,
              "title": "Head 1",
              "description": "Padrões locais de atenção."
            }
          },
          {
            "dwell": {
              "node": "h2",
              "effect": "processing",
              "ms": 400,
              "title": "Head 2",
              "delay": 80
            }
          },
          {
            "dwell": {
              "node": "h3",
              "effect": "processing",
              "ms": 400,
              "title": "Head 3",
              "delay": 160
            }
          }
        ]
      },
      {
        "narrate": {
          "title": "Fan-in — Concat",
          "description": "Saídas das heads são concatenadas e projetadas de volta a d_model.",
          "ms": 700
        }
      },
      {
        "parallel": [
          {
            "travel": {
              "edge": "ch1",
              "token": "default",
              "title": "Head 1 → Concat"
            }
          },
          {
            "travel": {
              "edge": "ch2",
              "token": "default",
              "title": "Head 2 → Concat",
              "delay": 100
            }
          },
          {
            "travel": {
              "edge": "ch3",
              "token": "default",
              "title": "Head 3 → Concat",
              "delay": 200
            }
          }
        ]
      },
      {
        "dwell": {
          "node": "concat",
          "effect": "waiting",
          "ms": 200,
          "title": "Concat",
          "description": "Aguarda todas as heads antes do merge."
        }
      },
      {
        "dwell": {
          "node": "concat",
          "effect": "processing",
          "ms": 220,
          "title": "Concat",
          "description": "torch.cat + projeção linear."
        }
      },
      {
        "travel": {
          "edge": "cn",
          "token": "default",
          "title": "Concat → Add+Norm",
          "description": "Residual connection + LayerNorm."
        }
      },
      {
        "dwell": {
          "node": "norm1",
          "effect": "processing",
          "ms": 180,
          "title": "Add+Norm",
          "description": "x + attn_out, normalizado."
        }
      },
      {
        "travel": {
          "edge": "nf",
          "token": "default",
          "title": "→ FFN",
          "description": "Feed-forward de duas camadas."
        }
      },
      {
        "dwell": {
          "node": "ffn",
          "effect": "processing",
          "ms": 900,
          "title": "FFN",
          "description": "Linear → GELU → Linear (4× d_model)."
        }
      },
      {
        "travel": {
          "edge": "fn",
          "token": "default",
          "title": "FFN → Add+Norm"
        }
      },
      {
        "dwell": {
          "node": "norm2",
          "effect": "processing",
          "ms": 180,
          "title": "Add+Norm",
          "description": "Segundo residual + normalização."
        }
      },
      {
        "travel": {
          "edge": "eout",
          "token": "default",
          "title": "Logits → LM head",
          "description": "Projeção final para vocabulário."
        }
      },
      {
        "wait": {
          "ms": 1200
        }
      }
    ]
  }
}
