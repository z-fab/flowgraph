{
  "title": "Process configs showcase",
  "viewport": { "height": 520, "padding": 50 },
  "metrics": { "nodePanel": true, "systemPanel": true },
  "randomness": { "enabled": true },
  "nodes": [
    { "id": "src", "type": "port", "role": "source", "shape": "circle", "icon": "play", "x": 60, "y": 260 },
    { "id": "proc", "type": "process", "label": "worker", "icon": "cog", "duration": 600, "x": 180, "y": 160,
      "pillTop": [{ "text": "duration", "tone": "primary" }] },
    { "id": "fanout", "type": "process", "label": "fan-out", "icon": "share-2", "duration": 200,
      "emit": { "mode": "all" }, "x": 180, "y": 360 },
    { "id": "join", "type": "process", "label": "fan-in", "icon": "git-merge", "duration": 500,
      "gate": { "from": ["e3", "e4"], "count": 1 }, "x": 340, "y": 260 },
    { "id": "rand", "type": "process", "label": "router", "icon": "shuffle", "duration": 300,
      "emit": { "mode": "weighted" }, "x": 500, "y": 160 },
    { "id": "batch", "type": "process", "label": "micro-batch", "icon": "layers", "duration": 150,
      "admission": { "mode": "batch", "max": 4, "step": 1 }, "x": 500, "y": 360,
      "pillTop": [{ "text": "accumulate", "tone": "warning" }] },
    { "id": "retry", "type": "process", "label": "retry loop", "icon": "repeat", "duration": 400,
      "retry": { "backEdge": "back", "maxRetries": 2 }, "x": 660, "y": 260 },
    { "id": "circ", "type": "process", "label": "circuit", "icon": "unplug", "duration": 300,
      "circuit": { "acceptEdge": "ok", "fallbackEdge": "fb", "failureRate": 0.3, "failureThreshold": 4, "recoveryMs": 5000 },
      "x": 820, "y": 160 },
    { "id": "sink", "type": "port", "role": "terminal", "label": "terminal", "icon": "flag", "tone": "success", "x": 980, "y": 260 },
    { "id": "fb", "type": "port", "role": "sink", "shape": "circle", "icon": "archive", "tone": "warning", "x": 980, "y": 100 }
  ],
  "edges": [
    { "id": "e1", "from": "src", "to": "proc" },
    { "id": "e2", "from": "src", "to": "fanout" },
    { "id": "e3", "from": "proc", "to": "join" },
    { "id": "e4", "from": "fanout", "to": "join" },
    { "id": "e5", "from": "join", "to": "rand" },
    { "id": "e6", "from": "join", "to": "batch" },
    { "id": "e7", "from": "rand", "to": "retry", "weight": 7 },
    { "id": "e8", "from": "batch", "to": "retry" },
    { "id": "ok", "from": "circ", "to": "sink", "stroke": { "color": "success" } },
    { "id": "fb", "from": "circ", "to": "fb", "stroke": { "dash": "dash", "color": "warning" } },
    { "id": "e9", "from": "retry", "to": "circ" },
    { "id": "back", "from": "retry", "to": "join", "routing": "loopback", "stroke": { "dash": "dot" } }
  ],
  "sources": [
    { "edge": "e1", "interval": 4000 },
    { "edge": "e2", "interval": 4500, "token": { "color": "#D97706" } }
  ]
}
