{
  "title": "SSE stream",
  "viewport": { "height": 320, "padding": 50 },
  "nodes": [
    { "id": "client", "type": "port", "role": "source", "label": "Client", "shape": "circle", "icon": "monitor", "x": 90, "y": 160 },
    { "id": "api", "type": "process", "label": "Stream API", "icon": "radio", "duration": 500, "x": 270, "y": 160 },
    { "id": "llm", "type": "process", "label": "LLM", "icon": "brain", "duration": 800, "x": 430, "y": 160, "tone": "primary",
      "emit": { "mode": "all", "count": 4 } },
    { "id": "out", "type": "port", "role": "sink", "label": "Browser", "icon": "message-square", "tone": "success", "x": 590, "y": 160, "showReceived": true }
