{
  "title": "MLP — forward & backprop",
  "viewport": { "height": 420, "padding": 55 },
  "tokens": { "color": "#7C3AED", "shape": "roundedRect", "size": 6, "speed": 95 },
  "nodes": [
    { "id": "input", "type": "port", "role": "source", "shape": "circle", "icon": "binary", "x": 70, "y": 170,
