{
  "title": "MapReduce",
  "viewport": {
    "height": 440,
    "padding": 60
  },
  "tokens": {
    "color": "#7C3AED",
    "speed": 85,
    "size": 6
  },
  "tokenTypes": {
    "default": {
      "color": "#7C3AED",
      "speed": 85,
      "size": 6
    }
  },
  "controls": {
    "metricsDrawer": false
  },
  "nodes": [
    {
      "id": "in",
      "type": "port",
      "role": "source",
      "label": "Input",
      "shape": "circle",
      "icon": "inbox",
      "x": 70,
      "y": 220
    },
    {
      "id": "disp",
      "type": "process",
      "label": "Dispatcher",
      "icon": "share-2",
      "x": 220,
      "y": 220
    },
    {
      "id": "w1",
      "type": "process",
      "label": "Worker 1",
      "icon": "cpu",
      "x": 430,
      "y": 70
    },
    {
      "id": "w2",
      "type": "process",
      "label": "Worker 2",
      "icon": "cpu",
      "x": 430,
      "y": 220
    },
    {
      "id": "w3",
      "type": "process",
      "label": "Worker 3",
      "icon": "cpu",
      "x": 430,
      "y": 370
    },
    {
      "id": "agg",
      "type": "process",
      "label": "Aggregator",
      "icon": "layers",
      "x": 620,
      "y": 220,
      "pillTop": [{ "text": "fan-in", "tone": "primary" }]
    },
    {
      "id": "out",
      "type": "port",
      "role": "terminal",
      "label": "Output",
      "tone": "success",
      "x": 770,
      "y": 220
    }
  ],
  "edges": [
    {
      "id": "d1",
      "from": "in",
      "to": "disp",
      "label": { "text": "job" }
    },
    {
      "id": "d2",
      "from": "disp",
      "to": "w1",
      "label": { "text": "w1" }
    },
    {
      "id": "d3",
      "from": "disp",
      "to": "w2",
      "label": { "text": "w2" }
    },
    {
      "id": "d4",
      "from": "disp",
      "to": "w3",
      "label": { "text": "w3" }
    },
    { "id": "a1", "from": "w1", "to": "agg" },
    { "id": "a2", "from": "w2", "to": "agg" },
    { "id": "a3", "from": "w3", "to": "agg" },
    {
      "id": "a4",
      "from": "agg",
      "to": "out",
      "stroke": { "color": "success" },
      "label": { "text": "result" }
    }
  ],
  "scenario": {
    "loop": true,
    "playInterval": 500,
    "narration": { "showOnCanvas": true, "position": "top-left" },
    "steps": [
      {
        "narrate": {
          "title": "Fan-out / fan-in",
          "description": "Um job é dividido entre workers e os resultados são agregados.",
          "ms": 700
        }
      },
      {
        "travel": {
          "edge": "d1",
          "token": "default",
          "title": "Input → Dispatcher"
        }
      },
      {
        "dwell": {
          "node": "disp",
          "effect": "processing",
          "ms": 300,
          "title": "Dispatcher",
          "description": "Particiona o job em shards."
        }
      },
      {
        "parallel": [
          {
            "travel": {
              "edge": "d2",
              "token": "default",
              "title": "→ Worker 1"
            }
          },
          {
            "travel": {
              "edge": "d3",
              "token": "default",
              "title": "→ Worker 2",
              "delay": 120
            }
          },
          {
            "travel": {
              "edge": "d4",
              "token": "default",
              "title": "→ Worker 3",
              "delay": 240
            }
          }
        ]
      },
      {
        "parallel": [
          {
            "dwell": {
              "node": "w1",
              "effect": "processing",
              "ms": 500,
              "title": "Worker 1"
            }
          },
          {
            "dwell": {
              "node": "w2",
              "effect": "processing",
              "ms": 650,
              "title": "Worker 2",
              "delay": 80
            }
          },
          {
            "dwell": {
              "node": "w3",
              "effect": "processing",
              "ms": 450,
              "title": "Worker 3",
              "delay": 160
            }
          }
        ]
      },
      {
        "parallel": [
          { "travel": { "edge": "a1", "token": "default" } },
          { "travel": { "edge": "a2", "token": "default", "delay": 100 } },
          { "travel": { "edge": "a3", "token": "default", "delay": 200 } }
        ]
      },
      {
        "dwell": {
          "node": "agg",
          "effect": "waiting",
          "ms": 350,
          "title": "Aggregator",
          "description": "Aguarda todos os partial results."
        }
      },
      {
        "dwell": {
          "node": "agg",
          "effect": "processing",
          "ms": 500,
          "title": "Aggregator",
          "description": "Reduce dos resultados parciais."
        }
      },
      {
        "travel": {
          "edge": "a4",
          "token": "default",
          "title": "Resultado final",
          "description": "Output único após o fan-in."
        }
      },
      { "wait": { "ms": 1000 } }
    ]
  }
}
